{
  "Section": {
    "prefix": "sec",
    "body": [
      "\\section{${1:Title}}",
      "${0}"
    ],
    "description": "Insert section"
  },
  "Subsection": {
    "prefix": "ssec",
    "body": [
      "\\subsection{${1:Title}}",
      "${0}"
    ],
    "description": "Insert subsection"
  },
  "Begin-End Environment": {
    "prefix": "beg",
    "body": [
      "\\begin{${1:environment}}",
      "  ${0}",
      "\\end{${1:environment}}"
    ],
    "description": "Generic begin/end block"
  },
  "Equation": {
    "prefix": "eq",
    "body": [
      "\\begin{equation}",
      "  ${0}",
      "\\end{equation}"
    ],
    "description": "Insert equation environment"
  },
  "Align": {
    "prefix": "ali",
    "body": [
      "\\begin{align}",
      "  ${0}",
      "\\end{align}"
    ],
    "description": "Insert align environment"
  },
  "Itemize": {
    "prefix": "it",
    "body": [
      "\\begin{itemize}",
      "  \\item ${1:first item}",
      "  ${0}",
      "\\end{itemize}"
    ],
    "description": "Insert itemize environment"
  },
  "Enumerate": {
    "prefix": "en",
    "body": [
      "\\begin{enumerate}",
      "  \\item ${1:first item}",
      "  ${0}",
      "\\end{enumerate}"
    ],
    "description": "Insert enumerate environment"
  },
  "Figure": {
    "prefix": "fig",
    "body": [
      "\\begin{figure}[${1:htbp}]",
      "  \\centering",
      "  \\includegraphics[width=${2:0.8}\\linewidth]{${3:figure.pdf}}",
      "  \\caption{${4:Caption}}",
      "  \\label{fig:${5:key}}",
      "\\end{figure}",
      "${0}"
    ],
    "description": "Insert figure block"
  },
  "Table": {
    "prefix": "tab",
    "body": [
      "\\begin{table}[${1:htbp}]",
      "  \\centering",
      "  \\begin{tabular}{${2:cc}}",
      "    ${3:a} & ${4:b} \\\\",
      "  \\end{tabular}",
      "  \\caption{${5:Caption}}",
      "  \\label{tab:${6:key}}",
      "\\end{table}",
      "${0}"
    ],
    "description": "Insert table block"
  },
  "Theorem": {
    "prefix": "thm",
    "body": [
      "\\begin{theorem}",
      "  ${0}",
      "\\end{theorem}"
    ],
    "description": "Insert theorem environment"
  },
  "Lemma": {
    "prefix": "lem",
    "body": [
      "\\begin{lemma}",
      "  ${0}",
      "\\end{lemma}"
    ],
    "description": "Insert lemma environment"
  },
  "Proof": {
    "prefix": "prf",
    "body": [
      "\\begin{proof}",
      "  ${0}",
      "\\end{proof}"
    ],
    "description": "Insert proof environment"
  },
  "Label": {
    "prefix": "lbl",
    "body": "\\label{${1:key}}",
    "description": "Insert label"
  },
  "Reference": {
    "prefix": "ref",
    "body": "\\ref{${1:key}}",
    "description": "Insert reference"
  },
  "Cite": {
    "prefix": "cite",
    "body": "\\cite{${1:key}}",
    "description": "Insert citation"
  }
}
